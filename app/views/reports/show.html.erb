<div class="report-show"
     data-controller="pdf"
     data-pdf-filename-value="report_<%= @report.id %>.pdf">

  <div data-pdf-target="content">
    <h1>Titre : <%= @report.title %></h1>

    <div class="report-info">
      <p><strong>Status:</strong> <%= @report.status %></p>
      <p><strong>Version:</strong> <%= @report.report_version_number %></p>
      <p><strong>Template:</strong> <%= @report.report_template.name %></p>
      <p><strong>User:</strong> <%= @report.user.email %></p>
      <p><strong>Created:</strong> <%= @report.created_at.strftime("%B %d, %Y") %></p>
    </div>

    <% if @report.report_entries.any? %>
      <h2>Report Entries</h2>
      <table class="report-entries">
        <thead>
          <tr>
            <td><%= entry.label %></td>
            <td><%= entry.label == "Titre" ? @report.title : entry.value_text %></td>
          </tr>
        </thead>
        <tbody>
          <% @report.report_entries.each do |entry| %>
            <tr>
              <td><%= entry.label %></td>
              <td><%= entry.value_text %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No entries added yet.</p>
    <% end %>
  </div>

