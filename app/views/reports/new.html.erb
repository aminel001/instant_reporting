<section class="hero-section d-flex align-items-center justify-content-center text-white text-center py-5" style="background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); min-height: 500px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <h1 class="display-4 fw-bold mb-4">Let's create a new report</h1>
              <%= simple_form_for [@report_template, @report] do |f| %>
                <%= f.input :title %>
                <%= f.submit "create report", class: "btn btn-primary" %>
              <% end %>


      </div>
    </div>
  </div>
</section>
