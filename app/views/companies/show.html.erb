<h1><%= @company.name%></h1>
<%= cl_image_tag(@company.logo.key, height: 30, width: 80) if @company.logo.attached? && @company.logo.key.present? %>
<h1><%= @company.description%></h1>
<p> list of employees </p>
<table class="table">
  <thead>
    <tr>
      <th>Photo</th>
      <th>Full Name</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @company.users.each do |user| %>
      <tr>
        <td>
          <% if user.profile_photo.attached? %>
            <%= image_tag user.profile_photo, width: 50, height: 50 %>
          <% else %>
            No photo
          <% end %>
        </td>
        <td><%= "#{user.first_name} #{user.last_name}" %></td>
        <td><%= user.role %></td>
        <td>
          <% if policy(user).edit? %>
            <%= link_to "Edit", edit_user_path(user), class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="text-center">
    <%= link_to "Edit", edit_company_path, class: "btn btn-outline-primary" %>
    <%= link_to "Back", companies_path, class: "btn btn-outline-primary" %>
</div>
