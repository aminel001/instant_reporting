<div class="companies-page">

  <div class="container">

    <!-- TITLE -->
    <div class="text-center mb-5">
      <h1 class="companies-title">Companies</h1>
      <p class="companies-subtitle">Manage your companies easily</p>
    </div>

    <!-- LIST -->
    <div class="companies-list">
      <% @companies.each do |company| %>
        <div class="company-card">
          <div class="d-flex align-items-center justify-content-between">

            <div class="d-flex align-items-center gap-3">
              <div class="company-avatar">
                <%= company.name.first.upcase %>
              </div>

              <div>
                <h5 class="mb-0"><%= company.name %></h5>
              </div>
            </div>

            <%= link_to "View", company_path(company), class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- BUTTON -->
    <div class="text-center mt-5">
      <%= link_to "Create New Company", new_company_path, class: "btn company-main-btn" %>
    </div>

  </div>

</div>
