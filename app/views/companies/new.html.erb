<div class="company-form-page">

  <div class="container">

    <div class="company-form-card">

      <!-- TITLE -->
      <div class="text-center mb-4">
        <h2 class="company-form-title">New Company</h2>
        <p class="company-form-subtitle">Create a new company profile</p>
      </div>

      <!-- FORM -->
      <%= simple_form_for(@company) do |f| %>

        <div class="company-form-field">
          <%= f.input :name, input_html: { class: "form-control" } %>
        </div>

        <div class="company-form-field">
          <%= f.input :description, input_html: { class: "form-control" } %>
        </div>

        <div class="company-form-field">
          <%= f.input :logo do %>
            <%= f.file_field :logo, class: "form-control" %>
          <% end %>
        </div>

        <div class="text-center mt-4">
          <%= f.submit "Create Company", class: "btn btn-primary px-4" %>
        </div>

      <% end %>

    </div>

  </div>

</div>
