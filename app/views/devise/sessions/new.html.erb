<section class="auth-section d-flex align-items-center justify-content-center">
  <div class="auth-card">

    <h2 class="auth-title">Welcome Back 👋</h2>
    <p class="auth-subtitle">Login to your dashboard</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="auth-input">
        <%= f.input :email,
          label: false,
          required: false,
          input_html: { placeholder: "Enter your email", autocomplete: "email" } %>
      </div>

      <div class="auth-input">
        <%= f.input :password,
          label: false,
          required: false,
          input_html: { placeholder: "Enter your password", autocomplete: "current-password" } %>
      </div>

      <div class="auth-remember d-flex justify-content-between align-items-center">
        <%= f.input :remember_me, as: :boolean, label: "Remember me" if devise_mapping.rememberable? %>
        <%= link_to "Forgot password?", new_user_password_path, class: "auth-link" %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit, "Log in", class: "auth-btn" %>
      </div>

    <% end %>

  </div>
</section>
