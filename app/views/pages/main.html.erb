
<section class="hero-section d-flex align-items-center text-white pt-2 pb-5"
  style="background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); min-height: 100px;">

  <div class="container position-relative">

    <!-- TOP LEFT: logo + company -->
    <div class="d-flex align-items-center gap-2 position-absolute top-0 start-0 mt-3 ms-3">
      <div style="width: 64px; height: 64px;" class="d-flex align-items-center justify-content-center">
        <% if current_user.company.logo.present? %>
          <%= cl_image_tag current_user.company.logo.key,
            height: 128,
            width: 128,
            crop: :limit,
            class: "rounded" %>
        <% else %>
          <div class="bg-light text-dark rounded d-flex align-items-center justify-content-center"
            style="width: 64px; height: 64px;">
            <%= current_user.company.name.first.upcase %>
          </div>
        <% end %>
      </div>

      <span class="fs-5 fw-semibold"><%= current_user.company.name %></span>
    </div>

    <!-- CENTERED CONTENT -->
    <div class="row text-center pt-5 mt-5">
      <div class="col-lg-8 mx-auto">
        <h1 class="display-4 fw-bold mb-4">Main Dashboard</h1>
        <p class="lead mb-5">Welcome back <%= current_user.first_name %>!</p>
      </div>
    </div>

  </div>
</section>

<section class="hero-section d-flex align-items-center justify-content-center text-white text-center py-5" style="background: linear-gradient(135deg, #6e7174 0%, #909497 0%); min-height: 100px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <h1 class="display-4 fw-bold mb-4">Initiate a report</h1>
        <p class="lead mb-5">Select a report template</p>
        <%= link_to "Template A", new_report_template_reports_path(ReportTemplate.first), class: "btn btn-light btn-lg me-3" %>
        <%= link_to "Template B", new_report_template_reports_path(ReportTemplate.second), class: "btn btn-light btn-lg me-3" %>
        <%= link_to "Template C", new_report_template_reports_path(ReportTemplate.third), class: "btn btn-light btn-lg me-3" %>
      </div>
    </div>
  </div>
</section>

<section class="hero-section d-flex align-items-center justify-content-center text-white text-center py-5" style="background: linear-gradient(135deg, #ced2d7 0%, #ced3d6 0%); min-height: 500px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-18 mx-auto">
        <h1 class="display-4 fw-bold mb-4">Work on an existing report</h1>
        <p class="lead mb-4">List of <%= current_user.company.name.capitalize %>'s reports</p>
        <div class="table-responsive">
          <table class="table table-striped table-bordered bg-white text-dark rounded">
            <thead class="table-dark">
              <tr>
                <th>Date</th>
                <th>Title</th>
                <th>Status</th>
                <th>Ver.</th>
                <th>Templ.</th>
                <th>Author</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @reports.each do |report| %>
                <tr>
                  <td><%= report.created_at.strftime("%d %b %y") %></td>
                  <td><%= report.title %></td>
                  <td><%= report.status %></td>
                  <td>V<%= report.report_version_number %></td>
                  <td><%= report.report_template.name %></td>
                  <td><%= "#{report.user.first_name} #{report.user.last_name}" %></td>
                  <td class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-success btn-sm">Approve</button>
                    <button class="btn btn-warning btn-sm">Edit</button>
                    <button class="btn btn-danger btn-sm">Delete</button>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
