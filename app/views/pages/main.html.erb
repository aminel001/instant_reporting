<div class="main-dashboard">

  <section class="main-dashboard-hero d-flex align-items-center pt-2 pb-5">
    <div class="container position-relative">

      <div class="main-company-card d-flex align-items-center gap-2 position-absolute top-0 start-0 mt-3 ms-3">
        <div style="width: 64px; height: 64px;" class="d-flex align-items-center justify-content-center">
          <% if current_user.company.logo.present? %>
            <%= cl_image_tag current_user.company.logo.key, height: 64, width: 64, crop: :limit, class: "rounded" %>
          <% else %>
            <div class="main-company-placeholder rounded d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
              <%= current_user.company.name.first.upcase %>
            </div>
          <% end %>
        </div>

        <span class="fs-5 fw-semibold"><%= current_user.company.name %></span>
      </div>

      <div class="row text-center pt-5 mt-5">
        <div class="col-lg-8 mx-auto">
          <h1 class="display-4 fw-bold mb-4">Main Dashboard</h1>
          <p class="lead mb-5">Welcome back <%= current_user.first_name %>!</p>
        </div>
      </div>

    </div>
  </section>

  <section class="main-dashboard-section d-flex align-items-center justify-content-center text-center py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto">
          <h1 class="display-4 fw-bold mb-4">Initiate a report</h1>
          <p class="lead mb-5">Select a report template</p>

          <%= link_to "Template A", new_report_template_reports_path(ReportTemplate.first), class: "btn main-dashboard-btn btn-lg me-3" %>
          <%= link_to "Template B", new_report_template_reports_path(ReportTemplate.second), class: "btn main-dashboard-btn btn-lg me-3" %>
          <%= link_to "Template C", new_report_template_reports_path(ReportTemplate.third), class: "btn main-dashboard-btn btn-lg me-3" %>
        </div>
      </div>
    </div>
  </section>

  <section class="main-dashboard-section main-dashboard-reports d-flex align-items-center justify-content-center text-center py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-18 mx-auto">
          <h1 class="display-4 fw-bold mb-4">Work on an existing report</h1>
          <p class="lead mb-4">List of <%= current_user.company.name.capitalize %>'s reports</p>

          <div class="table-responsive main-dashboard-table-wrap">
            <table class="table table-striped table-bordered bg-white text-dark rounded">
              <thead class="table-dark">
                <tr>
                  <th>Date</th>
                  <th>Title</th>
                  <th>Status</th>
                  <th>Ver.</th>
                  <th>Templ.</th>
                  <th>Author</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @reports.each do |report| %>
                  <tr>
                    <td><%= report.created_at.strftime("%d %b %y") %></td>
                    <td><%= link_to report.title, report_path(report.id) %></td>
                    <td><%= report.status %></td>
                    <td>V<%= report.report_version_number %></td>
                    <td><%= report.report_template.name %></td>
                    <td><%= "#{report.user.first_name} #{report.user.last_name}" %></td>
                    <td class="d-flex gap-2 justify-content-center">
                      <%= link_to "View", report_path(report.id), class: "btn btn-outline-secondary btn-sm" %>
                      <%= link_to "Edit", edit_report_path(report.id), class: "btn btn-warning btn-sm" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

        </div>
      </div>
    </div>
  </section>

</div>
