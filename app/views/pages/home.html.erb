<section class="hero-dark">
  <div class="container">
    <div class="row align-items-center gy-5">
      <div class="col-lg-6">
        <div class="hero-dark__content">
          <div class="hero-dark__badge">
            <span>🏗️</span>
            Built for Civil Engineering Teams
          </div>

          <h1 class="hero-dark__title">
            Generate polished engineering reports
            <span>in minutes</span>
          </h1>

          <p class="hero-dark__text">
            Standardize your workflow, reduce repetitive formatting, and export
            professional PDF reports faster with a clean reporting platform
            built for modern teams.
          </p>

          <div class="hero-dark__actions d-flex flex-column flex-sm-row gap-3">
            <% if user_signed_in? %>
              <%= link_to "Go to Dashboard", main_path, class: "btn hero-dark__btn hero-dark__btn--primary btn-lg" %>
            <% else %>
              <%= link_to "Login to Start", new_user_session_path, class: "btn hero-dark__btn hero-dark__btn--primary btn-lg" %>
            <% end %>

            <a href="#problem" class="btn hero-dark__btn hero-dark__btn--secondary btn-lg">
              See How It Works
            </a>
          </div>

          <div class="hero-dark__stats row g-3">
            <div class="col-4">
              <div class="hero-dark-stat">
                <div class="hero-dark-stat__icon hero-dark-stat__icon--blue">⚡</div>
                <div class="hero-dark-stat__value">5x</div>
                <div class="hero-dark-stat__label">Faster reports</div>
              </div>
            </div>

            <div class="col-4">
              <div class="hero-dark-stat">
                <div class="hero-dark-stat__icon hero-dark-stat__icon--green">📄</div>
                <div class="hero-dark-stat__value">PDF</div>
                <div class="hero-dark-stat__label">Ready exports</div>
              </div>
            </div>

            <div class="col-4">
              <div class="hero-dark-stat">
                <div class="hero-dark-stat__icon hero-dark-stat__icon--purple">👥</div>
                <div class="hero-dark-stat__value">24/7</div>
                <div class="hero-dark-stat__label">Team access</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="hero-dark__media">
          <div class="hero-dark__image-wrap">
            <%= image_tag "hero-report-dashboard.png", alt: "Construction reporting platform", class: "hero-dark__image" %>

            <div class="hero-dark__image-overlay"></div>

            <div class="hero-dark__floating hero-dark__floating--top">
              <span class="hero-dark__floating-label">Instant Reporting</span>
              <strong>Construction-ready reports</strong>
            </div>

            <div class="hero-dark__floating hero-dark__floating--bottom">
              <div>
                <small>Export Speed</small>
                <strong>5x Faster</strong>
              </div>
              <div class="hero-dark__floating-dot"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="problem" class="problem-section py-5">
  <div class="container">
    <div class="section-heading text-center mb-5">
      <span class="section-kicker">Pain Points</span>
      <h2 class="section-title">The Problem</h2>
      <p class="section-subtitle">Manual reporting slows teams down and creates inconsistencies across projects.</p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="problem-card h-100 text-center">
          <div class="problem-icon">📋</div>
          <h3>Repetitive Work</h3>
          <p>Same structure, different data. Valuable hours are lost on formatting instead of engineering analysis.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="problem-card h-100 text-center">
          <div class="problem-icon">⚠️</div>
          <h3>Inconsistency</h3>
          <p>Different projects end up with different formats, which affects quality, clarity, and team efficiency.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="problem-card h-100 text-center">
          <div class="problem-icon">⏰</div>
          <h3>Time Pressure</h3>
          <p>Tight client deadlines leave less time for review, insights, and high-value technical work.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="how-it-works-section py-5">
  <div class="container">
    <div class="section-heading text-center mb-5">
      <span class="section-kicker">Workflow</span>
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">A simple process that turns raw project data into clean, client-ready reports.</p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="step-card text-center h-100">
          <div class="step-number">1</div>
          <h3>Choose Template</h3>
          <p>Select the right report template based on your project type and workflow needs.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="step-card text-center h-100">
          <div class="step-number">2</div>
          <h3>Fill in Data</h3>
          <p>Enter measurements, observations, and findings through simple and structured forms.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="step-card text-center h-100">
          <div class="step-number">3</div>
          <h3>Generate & Share</h3>
          <p>Export polished PDF reports and deliver professional results in a fraction of the time.</p>
        </div>
      </div>
    </div>
  </div>
</section>

